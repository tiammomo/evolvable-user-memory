# Copy to an ignored production env file or, preferably, inject equivalent
# values from the deployment secret manager. Never commit populated values.
EMF_POSTGRES_DB=evolvable_memory
EMF_POSTGRES_USER=emf
EMF_POSTGRES_PASSWORD=
EMF_DATABASE_URL=

EMF_MINIO_ROOT_USER=
EMF_MINIO_ROOT_PASSWORD=

EMF_AUTH_JWT_ISSUER=https://identity.example
EMF_AUTH_JWT_AUDIENCE=evolvable-memory-api
EMF_AUTH_JWT_JWKS_URL=https://identity.example/.well-known/jwks.json
EMF_AUTH_JWT_ALGORITHMS=RS256
EMF_AUTH_REQUIRED_SCOPE=memory
EMF_AUTH_AUDIT_HMAC_KEY=
EMF_GOVERNANCE_HMAC_KEY=
EMF_GOVERNANCE_PSEUDONYM_KEY_ID=governance-2026-01
EMF_PRIVACY_POLICY_VERSION=privacy-2026-01

EMF_PUBLIC_API_URL=https://memory-api.example
EMF_FRONTEND_URL=https://memory.example
EMF_CORS_ORIGINS=https://memory.example
