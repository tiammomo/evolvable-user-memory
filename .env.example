# Backend runtime. The application reads environment variables directly;
# copy or export these values before starting the process.
EMF_ENVIRONMENT=development
EMF_HOST=127.0.0.1
EMF_PORT=38089
EMF_LOG_LEVEL=INFO
# Use memory for a zero-dependency local run. PostgreSQL requires changing this
# to postgres, setting EMF_DATABASE_URL, and running evolvable-memory-migrate.
EMF_STORE=memory
EMF_DATABASE_URL=
EMF_DATABASE_POOL_MIN_SIZE=1
EMF_DATABASE_POOL_MAX_SIZE=10
# Maximum pool wait used only by /readyz; ordinary operations keep pool defaults.
EMF_DATABASE_READINESS_TIMEOUT_SECONDS=1.0

# Optional disposable semantic projection. It requires PostgreSQL authority and a
# separately running projector process. Default Compose enables these values.
EMF_PROJECTION_MODE=disabled
EMF_PROJECTION_REQUIRED=false
EMF_PROJECTION_NAME=milvus-memory-v1
EMF_PROJECTION_SEARCH_OVERSAMPLE=10
EMF_MILVUS_URI=http://127.0.0.1:19530
EMF_MILVUS_TOKEN=
EMF_MILVUS_COLLECTION=evolvable_memory_v1
EMF_MILVUS_CONSISTENCY_LEVEL=Bounded
EMF_MILVUS_TIMEOUT_SECONDS=5.0
EMF_MILVUS_MIN_SIMILARITY=0.15

# `hash` is deterministic and offline. `openai_compatible` calls
# {EMF_EMBEDDING_BASE_URL}/embeddings and should use a production-quality model.
EMF_EMBEDDING_PROVIDER=hash
EMF_EMBEDDING_MODEL=hash-blake2b-v1
EMF_EMBEDDING_DIMENSIONS=384
EMF_EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
EMF_EMBEDDING_API_KEY=
EMF_EMBEDDING_TIMEOUT_SECONDS=15.0

# Asynchronous outbox projector lease, retry, and dead-letter controls.
EMF_PROJECTION_WORKER_BATCH_SIZE=64
EMF_PROJECTION_WORKER_LEASE_SECONDS=60.0
EMF_PROJECTION_WORKER_POLL_SECONDS=1.0
EMF_PROJECTION_WORKER_RETRY_BASE_SECONDS=2.0
EMF_PROJECTION_WORKER_RETRY_MAX_SECONDS=300.0
EMF_PROJECTION_WORKER_MAX_ATTEMPTS=8
EMF_MAX_REQUEST_BODY_BYTES=1048576
# Local evaluation only. Staging/production must use jwt and configure all
# issuer/audience/JWKS/audit values below.
EMF_AUTH_MODE=development
EMF_AUTH_JWT_ISSUER=
EMF_AUTH_JWT_AUDIENCE=
EMF_AUTH_JWT_JWKS_URL=
EMF_AUTH_JWT_ALGORITHMS=RS256
EMF_AUTH_REQUIRED_SCOPE=memory
EMF_AUTH_AUDIT_HMAC_KEY=
EMF_FRONTEND_URL=http://127.0.0.1:33009
# Shared by backend service discovery and the standalone frontend's browser runtime config/CSP.
EMF_PUBLIC_API_URL=http://127.0.0.1:38089
EMF_CORS_ORIGINS=http://127.0.0.1:33009,http://localhost:33009

# Standalone static frontend.
EMF_FRONTEND_HOST=127.0.0.1
EMF_FRONTEND_PORT=33009

# Destructive PostgreSQL test fixtures are intentionally not enabled here.
# For a disposable database whose name ends in `_test`, export both variables
# only in the test shell:
# EMF_TEST_DATABASE_URL=postgresql://emf:password@127.0.0.1:5432/evolvable_memory_test
# EMF_ALLOW_DESTRUCTIVE_TEST_DATABASE=1
