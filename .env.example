# Backend runtime. The application reads environment variables directly;
# copy or export these values before starting the process.
EMF_ENVIRONMENT=development
EMF_HOST=127.0.0.1
EMF_PORT=38089
EMF_LOG_LEVEL=INFO
# Use memory for a zero-dependency local run. PostgreSQL requires changing this
# to postgres, setting EMF_DATABASE_URL, and running evolvable-memory-migrate.
EMF_STORE=memory
EMF_DATABASE_URL=
EMF_DATABASE_POOL_MIN_SIZE=1
EMF_DATABASE_POOL_MAX_SIZE=10
EMF_MAX_REQUEST_BODY_BYTES=1048576
EMF_FRONTEND_URL=http://127.0.0.1:33009
EMF_PUBLIC_API_URL=http://127.0.0.1:38089
EMF_CORS_ORIGINS=http://127.0.0.1:33009,http://localhost:33009

# Standalone static frontend.
EMF_FRONTEND_HOST=127.0.0.1
EMF_FRONTEND_PORT=33009
