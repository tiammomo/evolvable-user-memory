# Backend runtime. The application reads environment variables directly;
# copy or export these values before starting the process.
EMF_ENVIRONMENT=development
EMF_HOST=127.0.0.1
EMF_PORT=38089
EMF_LOG_LEVEL=INFO
EMF_STORE=memory

# Standalone static frontend.
EMF_FRONTEND_HOST=127.0.0.1
EMF_FRONTEND_PORT=33009
